// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Amber",
  },
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "buffer_font_size": 15.0,
  "buffer_line_height": "comfortable",
  "buffer_font_family": "Berkeley Mono SemiCondensed",
  "cursor_blink": false,
  "disable_ai": false,
  "format_on_save": "on",
  "preferred_line_length": 100,
  "relative_line_numbers": "enabled",
  "soft_wrap": "bounded",
  "show_whitespaces": "trailing",
  "show_wrap_guides": false,
  "ui_font_family": ".SystemUIFont",
  "vim_mode": true,
  "auto_install_extensions": {
    "color-highlight": true,
    "fish": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_features": {
    "calt": false,
    // "ss01": true,
    // "wdth": 90,
  },
  "edit_predictions": {
    "provider": "none",
  },
  "gutter": {
    "min_line_number_digits": 0,
  },
  "languages": {
    "Python": {
      "language_servers": [
        // Enable ty, disable basedpyright, and enable all
        // other registered language servers (ruff, pylsp, pyright).
        "ty",
        "!basedpyright",
      ],
    },
  },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
    "auto_fold_dirs": false,
  },
  "ssh_connections": [
    {
      "host": "10.0.1.2",
      "username": "roly",
      "projects": [
        {
          "paths": ["~/Developer"],
        },
      ],
    },
  ],
  "terminal": {
    "font_family": "Berkeley Mono",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_sign_in": false,
  },
  "experimental.theme_overrides": {
    // "background": "#000000d7",
    "background.appearance": "blurred",
    // "border": "#ffffff22",
    // "border.variant": "#ffffff11",
    // "editor.active_line.background": "#00000000",
    // "editor.background": "#00000000",
    // "editor.document_highlight.read_background": "#5c78e225",
    // "editor.document_highlight.write_background": "#a3a3a466",
    // "editor.gutter.background": "#00000000",
    // "elevated_surface.background": "#2f343eff",
    // "panel.background": "#00000000",
    // "scrollbar.track.border": "#00000000",
    // "status_bar.background": "#000000d7",
    // "tab.active_background": "#282c3380",
    // "tab.inactive_background": "#00000000",
    // "tab_bar.background": "#000000d7",
    "terminal.background": "#000000",
    "terminal.foreground": "#ffbf00",
    "terminal.ansi.black": "#262626",
    "terminal.ansi.red": "#cd0400",
    "terminal.ansi.green": "#ffbf00",
    "terminal.ansi.yellow": "#ffbf00",
    "terminal.ansi.blue": "#ffbf00",
    "terminal.ansi.magenta": "#ffbf00",
    "terminal.ansi.cyan": "#ffbf00",
    "terminal.ansi.white": "#fefeff",
    "terminal.ansi.bright_black": "#484747",
    "terminal.ansi.bright_red": "#cd0400",
    "terminal.ansi.bright_green": "#ff8c00",
    "terminal.ansi.bright_yellow": "#ff8c00",
    "terminal.ansi.bright_blue": "#ff8c00",
    "terminal.ansi.bright_magenta": "#ff8c00",
    "terminal.ansi.bright_cyan": "#ff8c00",
    "terminal.ansi.bright_white": "#ffffff",
    // "title_bar.background": "#000000ee",
    // "title_bar.inactive_background": "#000000d7",
    // "toolbar.background": "#00000000",
  },
}
