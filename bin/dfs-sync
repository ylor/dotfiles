#!/usr/bin/env fish
set --query DOTFILES || dfs-init
set --local DOTFILES_CACHE "$HOME/.cache/dotfiles/cache.txt"
set --local DOTFILES_CACHE "cache.txt"

mkdir -p (dirname $DOTFILES_CACHE)

for orig in (fd . "$DOTFILES/home" --hidden --absolute-path --type file)
    set link (string replace "$DOTFILES/home" "$HOME" "$orig")
    mkdir -p (dirname $link)
    ln -sfv $orig $link
    echo "$link" >> $DOTFILES_CACHE
end
sort -uo $DOTFILES_CACHE $DOTFILES_CACHE

while read -l link
    if not test -e $link
        rm -v $link
    end
end < file.txt

for dir in (path dirname (cat file.txt) | sort -u)
    find $dir -maxdepth 1 -type d -empty -delete 2>/dev/null
end
