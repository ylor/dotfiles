#!/usr/bin/env fish
set --query DOTFILES || dfs

# link dotfiles
set --local links
for orig in (fd . "$DOTFILES/home" --hidden --absolute-path --type file)
    set link (string replace "$DOTFILES/home" "$HOME" "$orig")
    mkdir -p (path dirname $link)
    ln -sf $orig $link
    set_color green && printf "✓ "
    set_color normal && echo $link
    set --append links $link
end

set --local cache "$HOME/.cache/dotfiles/cache.txt"
mkdir -p (path dirname $cache)

# purge stale symlinks
test -f $cache && while read -l old
    contains $old $links || rm -vf $old
end < $cache

# replace cache
string join \n $links | sort > $cache

# purge empty dirs
for dir in (path dirname (cat $cache) | sort -u)
    find $dir -maxdepth 1 -type d -empty -delete 2>/dev/null
end

dfs-success "linked $(count $links) dotfiles"
