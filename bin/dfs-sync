#!/usr/bin/env fish
set --query DOTFILES || dfs-init

for orig in (fd . "$DOTFILES/home" --hidden --absolute-path --type file)
    set link (string replace "$DOTFILES/home" "$HOME" "$orig")
    mkdir -p (dirname $link)
    ln -sfv $orig $link
end

set -l dirs $HOME/.config $HOME/.local/bin $HOME/.local/share/applications
find -L $HOME -maxdepth 1 -type l -delete
find -L $dirs -type l -delete
find $dirs -type d -empty -delete
