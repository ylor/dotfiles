[
  {
    "bindings": {},
  },
  {
    "context": "Editor && VimControl && !VimWaiting",
    "bindings": {
      "space -": "pane::SplitHorizontal",
      "space =": "pane::SplitVertical",
      "space \\": "pane::SplitVertical",
      "space b": "tab_switcher::Toggle",
      "space f": "file_finder::Toggle",
      "space s g": "pane::DeploySearch",
      "space space": "pane::AlternateFile",
    },
  },
  {
    "context": "os == linux",
    "bindings": {
      "ctrl-a": "editor::SelectAll",
      "ctrl-c": "editor::Copy",
      "ctrl-f": ["buffer_search::DeployReplace", "buffer_search::Deploy"],
      "ctrl-v": "editor::Paste",
      "ctrl-x": "editor::Cut",
    },
  },
  {
    "context": "os == linux && Editor && VimControl && !VimWaiting",
    "bindings": {},
  },
  {
    "context": "os == macos",
    "bindings": {
      "cmd-a": "editor::SelectAll",
      "cmd-c": "editor::Copy",
      "cmd-f": ["buffer_search::DeployReplace", "buffer_search::Deploy"],
      "cmd-v": "editor::Paste",
      "cmd-x": "editor::Cut",
    },
  },
  {
    "context": "os == macos && Editor && VimControl && !VimWaiting",
    "bindings": {},
  },
]
